data arthritis1;<br>
	set arthritis;<br>
    t2=1; t3=0; newy=y2; output;<br>
    t2=0; t3=1; newy=y3; output;<br>
    t2=0; t3=0; newy=y1; output; <br>
	run;<br>

proc genmod data=arthritis1;<br>
    class sex id trt ;<br>
    model newy = sex age trt baseline t2 t3 / link=clogit dist=multinomial type3;<br>
    repeated subject = id;<br>
RUN;<br>

* proc print data=arthritis1;<br>
* run;<br>

data arthritis2;<br>
	set arthritis1;<br>
	newy1=0; newy2=0; newy3=0; <br>
    if t2=1 and y2=1 then newy1=1;<br>
    if t2=1 and y2=2 then newy2=1;<br>
    if t2=1 and y2=3 then newy3=1;<br>
    if t3=1 and y3=1 then newy1=1;<br>
    if t3=1 and y3=2 then newy2=1;<br>
    if t3=1 and y3=3 then newy3=1;<br>
    if t2=0 and t3=0 and y1=1 then newy1=1;<br>
    if t2=0 and t3=0 and y1=2 then newy2=1;<br>
    if t2=0 and t3=0 and y1=3 then newy3=1;<br>
run;<br>
	
* proc print data=arthritis2;<br>
* run;<br>


proc nlmixed data=arthritis2 qpoints=10; * cumul logit model;<br>
   bounds i2 > 0;<br>
   eta1 = i1 + sex*beta1 + trt*beta2+ baseline*beta3 + t2*beta4 + t3*beta5 +  u ;<br>
   eta2 = i1 + i2 + sex*beta1 + trt*beta2 + baseline*beta3 + t2*beta4 + t3*beta5 + u;<br>
  * note age deleted from model;<br>
   p1 = exp(eta1)/(1 + exp(eta1));<br>
   p2 = exp(eta2)/(1 + exp(eta2)) - exp(eta1)/(1 + exp(eta1));<br>
   p3 = 1 - exp(eta2)/(1 + exp(eta2));<br>
   ll = newy1*log(p1) + newy2*log(p2) + newy3*log(p3);<br>
   model newy1 ~ general(ll);<br>
   random u ~ normal(0, sigma*sigma) subject=id;<br>
run;
